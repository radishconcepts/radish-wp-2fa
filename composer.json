{
    "name": "radishconcepts/radish-wp-2fa",
    "description": "Enforceable, frontend-first two-factor authentication for WordPress.",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "keywords": [
        "wordpress",
        "wordpress-plugin",
        "two-factor",
        "2fa",
        "totp",
        "security"
    ],
    "homepage": "https://github.com/radishconcepts/radish-wp-2fa",
    "authors": [
        {
            "name": "Radish Concepts",
            "homepage": "https://www.radishconcepts.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "bacon/bacon-qr-code": "^2.0 || ^3.0",
        "composer/installers": "^1.0 || ^2.0",
        "pragmarx/google2fa": "^9.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "RadishConcepts\\TwoFactor\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "RadishConcepts\\TwoFactor\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit"
    },
    "extra": {
        "installer-name": "radish-2fa"
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true,
        "allow-plugins": {
            "composer/installers": true
        }
    }
}
